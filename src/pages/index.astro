---
import "../styles/global.css";

const featuredItems = [
  { name: "Sourdough Batard", price: "R20", desc: "48-hour fermented classic." },
  { name: "Almond Croissant", price: "R35", desc: "Twice-baked with frangipane." },
  { name: "Sea Salt Brownie", price: "R15", desc: "70% dark chocolate chunks." },
];

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Joes Bakery</title>
  </head>
  <body class="bg-stone-100 textstone-900 font-sans h-[10dvh]">
    <nav class="p-6 bg-amber-400 sticky">
      <h1 class="font-bold text-2xl">Joes Bakery</h1>
    </nav>
    <header
      class="relative h-[90dvh] flex items-center justify-center bg-stone-200 overflow-hidden"
    >
      <div class="z-10 text-center px-4">
        <h2 class="text-5xl md:text-7xl font-serif mb-4">
          Warmth in every crumb.
        </h2>
        <p class="text-lg md:text-xl text-stone-800 max-w-2xl mx-auto">
          Handcrafted breads and pastries baked fresh every single morning.
        </p>
      </div>
      <div
        class="absolute inset-0 opacity-40
			bg-[url('https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&q=80&w=2000')]
			bg-cover bg-center"
      >
      </div>
    </header>
	<section id="menu" class="py-20 max-w-6xl mx-auto px-6">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h3 class="text-3xl font-serif italic">Today's Specials</h3>
          <p class="text-stone-500">Straight from the oven</p>
        </div>
        <a href="#" class="text-amber-800 border-b border-amber-800 pb-1">View Full Menu</a>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        {featuredItems.map(item => (
          <div class="group cursor-pointer">
            <div class="aspect-square bg-stone-200 mb-4 overflow-hidden rounded-lg">
               <div class="w-full h-full bg-stone-300 group-hover:scale-105 transition duration-500">
				<img alt={item.name} src={`https://www.google.com/search?q=https://source.unsplash.com/featured/%3Fbakery,${item.name}`}/>
			   </div>
            </div>
            <div class="flex justify-between items-baseline">
              <h4 class="text-xl font-medium">{item.name}</h4>
              <span class="text-stone-500">{item.price}</span>
            </div>
            <p class="text-stone-600 mt-2 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </body>
</html>
